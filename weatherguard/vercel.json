{
  "version": 2,
  "builds": [
    {
      "src": "admin/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/src/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/src/main.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/admin/assets/$1"
    },
    {
      "src": "/(favicon\\.svg|manifest\\.json|.*\\.png|.*\\.avif)",
      "dest": "/admin/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/admin/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/weather",
      "schedule": "0 0 * * *"
    }
  ]
}
